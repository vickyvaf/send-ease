# Copy to .env and fill in (never commit .env)

# Wallet that will deploy (must hold CELO)
PRIVATE_KEY=0xyour_private_key_without_quotes

# Address allowed to execute schedules (optional, defaults to agent address)
# AGENT_ADDRESS=0xYourAgentAddress

# Default token — Celo mainnet USDm / cUSD
CUSD_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a

# RPC
CELO_RPC_URL=https://forno.celo.org

# Etherscan API V2 — required for forge verify on Celo (chain 42220)
# Create at https://etherscan.io/apidashboard (NOT the old celoscan-only V1 URL)
ETHERSCAN_API_KEY=your_etherscan_api_key
